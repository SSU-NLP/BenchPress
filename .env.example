# BenchPress v3 — env template
# Copy to `.env` and fill in real values. `.env` is gitignored; `.env.example` is committed.

# ---- Small model (Mapper) → OpenRouter ----
OPENROUTER_API_KEY=sk-or-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Large model (Executer / Maker / Improver) → self-hosted ----
# Used by Phase 1 LLMClientFactory when benchpress_config.json sets api_key_env=SELFHOST_API_KEY
# and base_url=null (factory falls back to SELFHOST_BASE_URL).
SELFHOST_BASE_URL=http://your-host:8000/v1
SELFHOST_API_KEY=replace-me

# ---- Legacy fallback used by old benchpress/ code path ----
# Optional: only needed if you run anything that still uses OpenAI directly.
# OPENAI_API_KEY=sk-replace-me

      "name": "Information Extraction and Filtering",
      "definition": "Identifying specific entities, values, or conditions within unstructured or semi-structured text and isolating them based on temporal, spatial, or categorical constraints."
    },
    {
      "id": "procedural_algorithmic_execution",
      "name": "Procedural and Algorithmic Execution",
      "definition": "Translating natural language specifications or abstract rules into a precise sequence of executable steps, simulations, or code to transform inputs into outputs."
    },
    {
      "id": "symbolic_mathematical_derivation",
      "name": "Symbolic and Mathematical Derivation",
      "definition": "Manipulating formal symbols, equations, and logical expressions using domain-specific axioms to derive exact numerical results or prove structural properties."
    },
    {
      "id": "domain_knowledge_retrieval",
      "name": "Domain Knowledge Retrieval",
      "definition": "Accessing and applying specific factual knowledge, definitions, theorems, or professional standards from long-term memory to interpret scenarios or validate claims."
    },
    {
      "id": "multi_step_decomposition",
      "name": "Multi-Step Problem Decomposition",
      "definition": "Breaking down complex, multi-constraint problems into a logical sequence of intermediate sub-tasks where later steps depend on the successful resolution of earlier ones."
    },
    {
      "id": "constraint_satisfaction_optimization",
      "name": "Constraint Satisfaction and Optimization",
      "definition": "Evaluating potential solutions against a set of rigid logical, physical, or resource boundaries to identify valid configurations or maximize/minimize a target objective."
    },
    {
      "id": "abstract_pattern_induction",
      "name": "Abstract Pattern Induction",
      "definition": "Analyzing limited examples or formal definitions to infer underlying structural rules, grammars, or transformation logic that govern a system's behavior."
    },
    {
      "id": "evidence_reconciliation_verification",
      "name": "Evidence Reconciliation and Verification",
      "definition": "Cross-checking derived conclusions, calculated values, or selected options against provided premises, distractors, or internal consistency checks to eliminate errors."
    },
    {
      "id": "spatial_structural_reasoning",
      "name": "Spatial and Structural Reasoning",
      "definition": "Mentally manipulating geometric coordinates, graph topologies, or data structures to determine relationships, paths, connectivity, or configuration changes."
    },
    {
      "id": "quantitative_aggregation_computation",
      "name": "Quantitative Aggregation and Computation",
      "definition": "Performing arithmetic operations, statistical calculations, or numerical estimations on extracted or derived values to produce a final quantitative answer."
    }
  ],
